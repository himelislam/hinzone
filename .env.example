# Server
NODE_ENV=development
SERVER_PORT=5000
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
# Set to 1 when deployed behind exactly one reverse proxy (nginx, a cloud load
# balancer); leave at 0 for local/direct-connection setups.
TRUST_PROXY_HOPS=0

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
AUTH_RATE_LIMIT_WINDOW_MINUTES=1
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_AVATAR_UPLOAD_SIZE_MB=5

# Client (Vite)
VITE_API_URL=http://localhost:5000/api/v1
