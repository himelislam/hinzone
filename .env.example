# Server
NODE_ENV=development
SERVER_PORT=5000
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
# Set to 1 when deployed behind exactly one reverse proxy (nginx, a cloud load
# balancer); leave at 0 for local/direct-connection setups.
TRUST_PROXY_HOPS=0

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# JWT
# Secrets only - access/refresh token expiration is a live Security Setting,
# configured through the admin panel (Settings > Security) instead, and seeded
# with defaults by `pnpm run seed:settings`.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Security
# Login attempts, account lock duration, and password-reset token expiration are
# also live Security Settings now - see the JWT note above. bcrypt cost and rate
# limiting aren't part of Security Settings, so they stay here.
BCRYPT_SALT_ROUNDS=12
AUTH_RATE_LIMIT_WINDOW_MINUTES=1
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_AVATAR_UPLOAD_SIZE_MB=5

# Client (Vite)
VITE_API_URL=http://localhost:5000/api/v1
